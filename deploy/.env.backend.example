# AutoGeo 后端生产环境变量配置
# 复制此文件为 .env.backend 并填入真实值

# ==================== 基础配置 ====================
# 后端镜像地址（阿里云ACR）
BACKEND_IMAGE=crpi-lwz264sedmauvivo.cn-guangzhou.personal.cr.aliyuncs.com/opencaio/auto_geo_backend:latest

# ==================== 加密配置（必填）====================
# AES-256 加密密钥（32字节）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTO_GEO_ENCRYPTION_KEY=your-32-byte-encryption-key-change-this

# ==================== 数据库配置（必填）====================
DB_USER=autogeo
DB_PASSWORD=your-secure-password-here
DB_NAME=autogeo
DB_PORT=5432

# 连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ==================== n8n 配置（必填）====================
# n8n服务器地址（IP+端口方式）
N8N_WEBHOOK_URL=http://your-n8n-server-ip:5678/webhook
N8N_API_KEY=your-n8n-api-key

# ==================== DeepSeek API（必填）====================
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==================== RAGFlow 配置（可选）====================
# RAGFlow独立部署地址
RAGFLOW_API_KEY=your-ragflow-api-key
RAGFLOW_BASE_URL=http://your-ragflow-server-ip:9380

# ==================== CORS配置 ====================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,app://.,file://,http://localhost:3000

# ==================== 阿里云ACR登录配置（可选）====================
# 用于私有镜像拉取 - 推荐：使用密码文件（更安全）
# 1. 创建密码文件: echo 'your-password' > /path/to/acr-password.txt && chmod 600 /path/to/acr-password.txt
# 2. 设置此变量指向密码文件
ALIYUN_ACR_PASSWORD_FILE=/path/to/acr-password.txt
ALIYUN_ACR_USERNAME=your-aliyun-username

# 或者使用环境变量（不推荐，密码可能泄漏到日志）
# ALIYUN_ACR_PASSWORD=your-password

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
