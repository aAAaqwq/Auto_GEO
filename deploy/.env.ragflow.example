# RAGFlow 部署环境变量配置
# 复制此文件为 .env.ragflow 并填入真实值

# ==================== MySQL配置 ====================
MYSQL_PASSWORD=your-mysql-password-here

# ==================== Redis配置 ====================
REDIS_PASSWORD=your-redis-password-here

# ==================== MinIO配置 ====================
MINIO_USER=minio
MINIO_PASSWORD=your-minio-password-here
