# ==================== 前端生产环境配置 ====================
# 复制此文件为 .env.production 并修改 API 地址

# API 基础地址（你的服务器地址）
VITE_API_BASE_URL=http://8.163.39.114/api

# WebSocket 地址
VITE_WS_URL=ws://8.163.39.114/ws

# 静态资源地址
VITE_STATIC_URL=http://8.163.39.114/static

# 是否启用 Mock（生产环境设为 false）
VITE_ENABLE_MOCK=false

# 应用标题
VITE_APP_TITLE=AutoGeo
