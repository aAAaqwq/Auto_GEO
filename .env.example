# ==================== AutoGeo 环境变量配置模板 (PostgreSQL版本) ====================
# 小a提醒：复制此文件为 .env 并填入真实值！
# 警告：.env 文件已在 .gitignore 中，不会被提交到 git

# ==================== 加密配置 ====================
# AES-256 加密密钥（32字节）
# 用于加密存储在数据库中的 Cookies 和 localStorage
# 重要：生产环境必须设置自己的密钥！
#
# 生成方法：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
AUTO_GEO_ENCRYPTION_KEY=your-32-byte-encryption-key-change-this

# ==================== 数据库配置 (PostgreSQL) ====================
# 如果使用Docker Compose部署，使用以下配置：
DB_USER=autogeo
DB_PASSWORD=your-secure-password-here
DB_NAME=autogeo
DB_PORT=5432

# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# 完整数据库URL（如果使用外部数据库，直接配置此项）
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ==================== 数据库配置 (SQLite - 开发环境) ====================
# 仅在开发环境使用SQLite时取消注释
# DATABASE_URL=sqlite:///./auto_geo.db

# ==================== 服务配置（可选）====================
# 后端服务地址
# HOST=127.0.0.1

# 后端服务端口
# PORT=8001

# 调试模式（生产环境建议设为 false）
# DEBUG=false

# ==================== n8n 工作流配置 ====================
# n8n Webhook 基础地址
# N8N_WEBHOOK_URL=http://n8n:5678/webhook

# ==================== RAGFlow 配置 ====================
RAGFLOW_BASE_URL=http://ragflow:9380
RAGFLOW_API_KEY=your-ragflow-api-key
RAGFLOW_DATASET_ID=
RAGFLOW_DATASET_NAME=reference_articles_kb
RAGFLOW_DUPLICATE_THRESHOLD=0.85

# ==================== DeepSeek 配置 ====================
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
